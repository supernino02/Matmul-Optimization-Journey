{
  "compiler": "icc",
  "flags_list": [
    "-fopenmp",
    "-Wall",
    "-Wextra",
    "-diag-disable=10441",
    "-DOPENMP",
    "-DALIGN",
    "-O3",
    "-ipo",
    "-xHost",
    "-inline-level=2",
    "-unroll-aggressive",
    "-unroll=4"
  ],
  "target": "executable",
  "version": "blas_like"
}
